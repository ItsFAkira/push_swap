{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "build all C and A files",
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}/src/*.c",
                "${workspaceFolder}/libft/src/**/*.c",
                "-I${workspaceFolder}/include",
                "-I${workspaceFolder}/libft/include",
				"-lm",
                "-o",
                "${workspaceFolder}test.out",
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
    ],
    "version": "2.0.0"
}
